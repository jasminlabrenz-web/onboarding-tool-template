# ============================================================================
# Onboarding-Tool — ENV-Variablen
# ============================================================================
# Kopiere diese Datei zu `.env.local` für lokale Entwicklung
# Für Vercel-Deploy: setze diese Variablen im Vercel-Dashboard

# ----------------------------------------------------------------------------
# PFLICHT — ohne diese läuft das Tool nicht
# ----------------------------------------------------------------------------

# Deine Email — hier landen die Dossiers, wenn Kundinnen absenden
BRAND_VA_EMAIL=du@deinedomain.de

# Passwort für den Admin-Bereich (/admin) — wähle was Sicheres
ADMIN_PASSWORD=

# Anthropic API-Key für die Dossier-Generierung
# Hole dir einen auf https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Resend API-Key für den Email-Versand
# Hole dir einen auf https://resend.com/api-keys (Free Tier reicht)
RESEND_API_KEY=

# ----------------------------------------------------------------------------
# BRANDING — kannst du jederzeit im Vercel-Dashboard ändern
# ----------------------------------------------------------------------------

# Dein Name (oder Firmenname) — wird im Header und in der Email gezeigt
BRAND_VA_NAME=Deine VA

# Hauptfarbe als Hex-Code (default = Jasmins Markenfarbe Lila/Blau)
BRAND_PRIMARY_COLOR=#7371FC

# Akzentfarbe (default = Jasmins Rose)
BRAND_ACCENT_COLOR=#fc60a8

# Logo-URL (optional, lade dein Logo z.B. zu Vercel Blob oder einer eigenen Domain)
BRAND_LOGO_URL=

# Begrüßungstext oben im Formular
BRAND_GREETING=Schön, dass du da bist! Bitte fülle das folgende Formular aus, damit ich dich optimal unterstützen kann.

# Absender-Adresse für die Mails an dich
# Default funktioniert ohne Domain-Verifikation, landet aber öfter im Spam
# Empfehlung nach 1–2 Wochen: eigene Domain bei Resend verifizieren und hier eintragen
BRAND_RESEND_FROM_EMAIL=onboarding@resend.dev

# Footer-Hinweis ausblenden (true/false)
FOOTER_HIDE=false

# ----------------------------------------------------------------------------
# VERCEL KV — wird automatisch gesetzt, wenn du KV mit dem Projekt verbindest
# ----------------------------------------------------------------------------
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
